#!/usr/bin/env python3
"""we-forgectl — we-forge service & operations control

Single-file CLI implementing:
  - install / uninstall / start / stop / restart / status
  - run (foreground) / daemon (long-running loop)
  - tui (rich-powered)  / dashboard (web)
  - notify-test / doctor

Architecture inspired by:
  - cokacctl (Rust, https://github.com/kstost/cokacctl) — ServiceManager trait,
    atomic plist writes, KeepAlive=true daemon model
  - hermes-gateway (Python, NousResearch/hermes-agent/scripts/hermes-gateway) —
    single-file CLI, OS dispatch, install/uninstall/start/stop/restart/status

Implements ECC marketplace skill patterns:
  - autonomous-agent-harness: persistent agent loops via Claude Code native
  - enterprise-agent-ops: lifecycle (start/pause/stop/restart), observability,
    safety controls, change management
  - safety-guard: backup-before-destroy on uninstall, dry-run default
  - dashboard-builder: operator-question dashboard (delegated to dashboard.py)

Modes:
  - scheduled (default): launchd StartCalendarInterval / systemd OnCalendar /
    Task Scheduler hourly. Same cost profile as classic cron.
  - daemon (--enable-telegram or --daemon): launchd KeepAlive=true / systemd
    Restart=always / Task Scheduler AtLogon. Long-running process; required
    when Telegram bot polling is enabled.

Data layout:
  ~/.we-forge/
    config.json         # mode, telegram opt-in, install metadata
    backup/             # uninstall backups
  ~/Library/LaunchAgents/com.we-forge.daemon.plist  (macOS)
  ~/.config/systemd/user/we-forge.service           (Linux)
  Windows Task Scheduler task: "we-forge"
"""

from __future__ import annotations

import argparse
import datetime as dt
import json
import os
import platform
import shutil
import subprocess
import sys
import time
from pathlib import Path

# ----------------------------------------------------------------------------
# Constants
# ----------------------------------------------------------------------------

CLAUDE_HOME    = Path(os.environ.get("CLAUDE_HOME", str(Path.home() / ".claude")))
WE_FORGE_HOME  = Path(os.environ.get("WE_FORGE_HOME", str(Path.home() / ".we-forge")))
CONFIG_FILE    = WE_FORGE_HOME / "config.json"
BACKUP_DIR     = WE_FORGE_HOME / "backup"
DAEMON_PID     = WE_FORGE_HOME / "daemon.pid"
ECC_TRACE_FILE = WE_FORGE_HOME / "ecc-trace.jsonl"

# Service identifiers
SERVICE_LABEL_MACOS  = "com.we-forge.daemon"
SERVICE_NAME_LINUX   = "we-forge"
TASK_NAME_WINDOWS    = "we-forge"

# Legacy LaunchAgent labels we know about — for migration
LEGACY_LABELS_MACOS = ["com.yukibana.we-forge-tick"]

# Daemon cadence — single source of truth
#
# Resolution order (first non-zero wins):
#   1. config.json "interval_minutes" field (set via `we-forgectl set-interval`)
#   2. WE_FORGE_DAEMON_INTERVAL env var (legacy, in seconds)
#   3. Default: 720 minutes (12 hours, fires at local 00:00 and 12:00)
#
# Tick scheduling is **aligned to local midnight** (00:00 in the system's local
# timezone). For interval=720min the slots are 00:00 and 12:00. For
# interval=30min the slots are 00:00, 00:30, ..., 23:30 (48 slots/day).
#
# The daemon re-reads this on every loop iteration so `set-interval` takes
# effect without a daemon restart.
DAEMON_INTERVAL_DEFAULT_MIN = 720  # 12 hours

def get_daemon_interval_seconds() -> int:
    """Resolve the daemon interval in seconds, hot-reloading from config."""
    try:
        cfg = json.loads(CONFIG_FILE.read_text(encoding="utf-8"))
        m = int(cfg.get("interval_minutes") or 0)
        if m > 0:
            return m * 60
    except (FileNotFoundError, json.JSONDecodeError, ValueError):
        pass
    env = int(os.environ.get("WE_FORGE_DAEMON_INTERVAL", "0") or 0)
    if env > 0:
        return env
    return DAEMON_INTERVAL_DEFAULT_MIN * 60

def next_aligned_tick_time(interval_sec: int, after: float) -> float:
    """Compute the next tick timestamp strictly AFTER `after`, aligned to
    local 00:00. Returns a Unix epoch float in the local timezone.

    interval_sec: tick cadence (seconds)
    after:        unix timestamp; the returned slot is > after
    """
    import datetime as _dt
    after_dt = _dt.datetime.fromtimestamp(after)  # local time
    midnight = after_dt.replace(hour=0, minute=0, second=0, microsecond=0)
    sec_since_midnight = (after_dt - midnight).total_seconds()
    # Strictly-next slot index (slot 0 = 00:00, slot 1 = +interval, etc.)
    next_slot_idx = int(sec_since_midnight // interval_sec) + 1
    next_slot_sec = next_slot_idx * interval_sec
    if next_slot_sec >= 86400:
        # Wrap to tomorrow's 00:00 + 0 (the first slot of tomorrow)
        target_dt = midnight + _dt.timedelta(days=1)
    else:
        target_dt = midnight + _dt.timedelta(seconds=next_slot_sec)
    return target_dt.timestamp()

# ----------------------------------------------------------------------------
# Output helpers
# ----------------------------------------------------------------------------

def _color(s: str) -> str:
    return s if sys.stdout.isatty() else ""

GREEN  = _color("\033[32m")
RED    = _color("\033[31m")
YELLOW = _color("\033[33m")
CYAN   = _color("\033[36m")
DIM    = _color("\033[2m")
BOLD   = _color("\033[1m")
RESET  = _color("\033[0m")

def step(msg: str) -> None:    print(f"{CYAN}==>{RESET} {msg}")
def ok(msg: str) -> None:      print(f"  {GREEN}OK  {RESET}{msg}")
def warn(msg: str) -> None:    print(f"  {YELLOW}WARN{RESET} {msg}")
def fail(msg: str) -> None:    print(f"  {RED}FAIL{RESET} {msg}", file=sys.stderr)
def info(msg: str) -> None:    print(f"  {DIM}{msg}{RESET}")

def now_iso() -> str:
    return dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

# ----------------------------------------------------------------------------
# Config (JSON file at ~/.we-forge/config.json)
# ----------------------------------------------------------------------------

def load_config() -> dict:
    if CONFIG_FILE.exists():
        try:
            return json.loads(CONFIG_FILE.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            warn(f"{CONFIG_FILE} is malformed; treating as empty")
    return {}

def save_config(cfg: dict) -> None:
    WE_FORGE_HOME.mkdir(parents=True, exist_ok=True)
    tmp = CONFIG_FILE.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(cfg, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    os.chmod(tmp, 0o600)
    tmp.replace(CONFIG_FILE)

# ----------------------------------------------------------------------------
# Platform detection
# ----------------------------------------------------------------------------

def detect_os() -> str:
    s = platform.system().lower()
    if s == "darwin":
        return "macos"
    if s == "linux":
        return "linux"
    if s == "windows":
        return "windows"
    return s

def is_wsl() -> bool:
    if detect_os() != "linux":
        return False
    try:
        return "microsoft" in Path("/proc/version").read_text().lower()
    except OSError:
        return False

# ----------------------------------------------------------------------------
# Service manager — abstract base + 3 platform impls
# (cokacctl ServiceManager trait pattern, ported to Python)
# ----------------------------------------------------------------------------

class ServiceManager:
    """Abstract OS service manager. Subclasses implement the platform calls."""

    def install(self, daemon: bool) -> None: raise NotImplementedError
    def uninstall(self) -> None:               raise NotImplementedError
    def start(self) -> None:                   raise NotImplementedError
    def stop(self) -> None:                    raise NotImplementedError
    def restart(self) -> None:
        self.stop()
        time.sleep(0.5)
        self.start()
    def status(self) -> str:                   raise NotImplementedError  # 'running'|'stopped'|'not-installed'
    def migrate_legacy(self) -> None: pass

# ---- macOS launchd ----------------------------------------------------------

class LaunchdManager(ServiceManager):
    def __init__(self) -> None:
        self.label    = SERVICE_LABEL_MACOS
        self.plist    = Path.home() / "Library/LaunchAgents" / f"{self.label}.plist"
        self.log_dir  = Path.home() / "Library/Logs/we-forge"
        self.uid      = os.getuid()
        self.domain   = f"gui/{self.uid}"

    def _generate_plist(self, daemon: bool) -> str:
        wforgectl_path = shutil.which("we-forgectl") or str(Path(__file__).resolve())
        log_path = str(self.log_dir / "daemon.log")
        if daemon:
            program_args = f"""
        <string>{wforgectl_path}</string>
        <string>daemon</string>"""
            keepalive_block = "    <key>RunAtLoad</key><true/>\n    <key>KeepAlive</key><true/>\n"
        else:
            program_args = f"""
        <string>{wforgectl_path}</string>
        <string>run-once</string>"""
            keepalive_block = (
                "    <key>StartCalendarInterval</key>\n"
                "    <dict><key>Minute</key><integer>0</integer></dict>\n"
                "    <key>RunAtLoad</key><false/>\n"
            )
        return f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>{self.label}</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/env</string>
        <string>python3</string>{program_args}
    </array>
{keepalive_block}    <key>StandardOutPath</key>
    <string>{log_path}</string>
    <key>StandardErrorPath</key>
    <string>{log_path}</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>CLAUDE_HOME</key>
        <string>{CLAUDE_HOME}</string>
        <key>WE_FORGE_HOME</key>
        <string>{WE_FORGE_HOME}</string>
    </dict>
</dict>
</plist>
"""

    def install(self, daemon: bool) -> None:
        self.log_dir.mkdir(parents=True, exist_ok=True)
        self.plist.parent.mkdir(parents=True, exist_ok=True)
        content = self._generate_plist(daemon)
        tmp = self.plist.with_suffix(".plist.tmp")
        tmp.write_text(content, encoding="utf-8")
        os.chmod(tmp, 0o600)
        tmp.replace(self.plist)
        ok(f"plist written: {self.plist}")
        target = f"{self.domain}/{self.label}"
        subprocess.run(["launchctl", "enable", target], capture_output=True)
        r = subprocess.run(["launchctl", "bootstrap", self.domain, str(self.plist)],
                           capture_output=True, text=True)
        if r.returncode != 0 and "already loaded" not in (r.stderr + r.stdout).lower():
            subprocess.run(["launchctl", "kickstart", "-k", target], capture_output=True)
        ok("launchctl bootstrap completed")

    def uninstall(self) -> None:
        target = f"{self.domain}/{self.label}"
        if self.plist.exists():
            subprocess.run(["launchctl", "bootout", target], capture_output=True)
            self.plist.unlink()
            ok(f"plist removed: {self.plist}")
        else:
            info(f"plist not present: {self.plist}")

    def start(self) -> None:
        target = f"{self.domain}/{self.label}"
        subprocess.run(["launchctl", "kickstart", target], check=True)
        ok(f"started {target}")

    def stop(self) -> None:
        subprocess.run(["launchctl", "stop", self.label], capture_output=True)
        ok(f"stopped {self.label}")

    def status(self) -> str:
        if not self.plist.exists():
            return "not-installed"
        target = f"{self.domain}/{self.label}"
        r = subprocess.run(["launchctl", "print", target], capture_output=True, text=True)
        if r.returncode != 0:
            return "stopped"
        text = r.stdout
        has_pid = any(line.strip().startswith("pid =") and "0" not in line for line in text.splitlines())
        running = "state = running" in text
        return "running" if (has_pid or running) else "stopped"

    def migrate_legacy(self) -> None:
        for legacy in LEGACY_LABELS_MACOS:
            legacy_plist = Path.home() / f"Library/LaunchAgents/{legacy}.plist"
            if legacy_plist.exists():
                step(f"migrating legacy LaunchAgent: {legacy}")
                subprocess.run(["launchctl", "bootout", f"{self.domain}/{legacy}"], capture_output=True)
                BACKUP_DIR.mkdir(parents=True, exist_ok=True)
                backup_dest = BACKUP_DIR / f"{legacy}.{now_iso()}.plist"
                shutil.copy2(legacy_plist, backup_dest)
                legacy_plist.unlink()
                ok(f"legacy removed (backup: {backup_dest})")

# ---- Linux systemd ----------------------------------------------------------

class SystemdManager(ServiceManager):
    def __init__(self) -> None:
        self.name        = SERVICE_NAME_LINUX
        unit_dir         = Path(os.environ.get("XDG_CONFIG_HOME", str(Path.home() / ".config"))) / "systemd/user"
        self.service_unit = unit_dir / f"{self.name}.service"
        self.timer_unit   = unit_dir / f"{self.name}.timer"
        self.log_dir      = Path(os.environ.get("XDG_STATE_HOME", str(Path.home() / ".local/state"))) / "we-forge"

    def _generate_service(self, daemon: bool) -> str:
        wforgectl_path = shutil.which("we-forgectl") or str(Path(__file__).resolve())
        cmd = "daemon" if daemon else "run-once"
        restart_block = "Restart=always\nRestartSec=30" if daemon else "Restart=on-failure\nRestartSec=30"
        return f"""[Unit]
Description=we-forge pattern-learning service ({"daemon" if daemon else "scheduled"})
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/env python3 {wforgectl_path} {cmd}
{restart_block}
StandardOutput=append:{self.log_dir}/daemon.log
StandardError=append:{self.log_dir}/daemon.log
Environment=CLAUDE_HOME={CLAUDE_HOME}
Environment=WE_FORGE_HOME={WE_FORGE_HOME}

[Install]
WantedBy=default.target
"""

    def _generate_timer(self) -> str:
        return f"""[Unit]
Description=we-forge hourly tick timer
Requires={self.name}.service

[Timer]
OnBootSec=5min
OnUnitActiveSec=1h
Persistent=true
Unit={self.name}.service

[Install]
WantedBy=timers.target
"""

    def install(self, daemon: bool) -> None:
        self.log_dir.mkdir(parents=True, exist_ok=True)
        self.service_unit.parent.mkdir(parents=True, exist_ok=True)
        self.service_unit.write_text(self._generate_service(daemon), encoding="utf-8")
        os.chmod(self.service_unit, 0o600)
        ok(f"service unit written: {self.service_unit}")
        if not daemon:
            self.timer_unit.write_text(self._generate_timer(), encoding="utf-8")
            os.chmod(self.timer_unit, 0o600)
            ok(f"timer unit written: {self.timer_unit}")
        subprocess.run(["systemctl", "--user", "daemon-reload"], check=True)
        target = f"{self.name}.timer" if not daemon else f"{self.name}.service"
        subprocess.run(["systemctl", "--user", "enable", "--now", target], check=True)
        ok(f"systemctl --user enable --now {target}")
        user = os.environ.get("USER") or os.environ.get("USERNAME")
        if user:
            r = subprocess.run(["loginctl", "show-user", user, "-p", "Linger"],
                               capture_output=True, text=True)
            if r.returncode == 0 and "Linger=yes" not in r.stdout:
                info(f"to keep service running after logout, run: sudo loginctl enable-linger {user}")

    def uninstall(self) -> None:
        for unit_name in (f"{self.name}.timer", f"{self.name}.service"):
            subprocess.run(["systemctl", "--user", "disable", "--now", unit_name],
                           capture_output=True)
        for u in (self.timer_unit, self.service_unit):
            if u.exists():
                u.unlink()
                ok(f"removed: {u}")
        subprocess.run(["systemctl", "--user", "daemon-reload"], capture_output=True)

    def start(self) -> None:
        target = f"{self.name}.timer" if self.timer_unit.exists() else f"{self.name}.service"
        subprocess.run(["systemctl", "--user", "start", target], check=True)
        ok(f"started {target}")

    def stop(self) -> None:
        for unit_name in (f"{self.name}.timer", f"{self.name}.service"):
            subprocess.run(["systemctl", "--user", "stop", unit_name], capture_output=True)
        ok("stopped")

    def status(self) -> str:
        target = f"{self.name}.timer" if self.timer_unit.exists() else f"{self.name}.service"
        if not (self.service_unit.exists() or self.timer_unit.exists()):
            return "not-installed"
        r = subprocess.run(["systemctl", "--user", "is-active", target],
                           capture_output=True, text=True)
        s = r.stdout.strip()
        return "running" if s == "active" else "stopped"

# ---- Windows Task Scheduler -------------------------------------------------

class TaskSchedulerManager(ServiceManager):
    def __init__(self) -> None:
        self.task_name = TASK_NAME_WINDOWS

    def _powershell(self, script: str) -> subprocess.CompletedProcess:
        return subprocess.run(
            ["powershell", "-NoProfile", "-NonInteractive", "-Command", script],
            capture_output=True, text=True
        )

    def install(self, daemon: bool) -> None:
        wforgectl_path = shutil.which("we-forgectl") or str(Path(__file__).resolve())
        cmd = "daemon" if daemon else "run-once"
        if daemon:
            trigger = "$trigger = New-ScheduledTaskTrigger -AtLogOn"
        else:
            trigger = (
                "$trigger = New-ScheduledTaskTrigger -Once "
                "-At ([DateTime]::Now.AddHours(1).Date.AddHours([DateTime]::Now.Hour + 1)) "
                "-RepetitionInterval (New-TimeSpan -Hours 1)"
            )
        script = f"""
$action = New-ScheduledTaskAction -Execute 'python3' -Argument '{wforgectl_path} {cmd}'
{trigger}
$settings = New-ScheduledTaskSettingsSet -AllowStartIfOnBatteries -DontStopIfGoingOnBatteries -StartWhenAvailable -ExecutionTimeLimit (New-TimeSpan -Minutes 10)
$principal = New-ScheduledTaskPrincipal -UserId "$env:USERNAME" -LogonType Interactive
$task = New-ScheduledTask -Action $action -Trigger $trigger -Settings $settings -Principal $principal -Description "we-forge pattern-learning service"
Unregister-ScheduledTask -TaskName "{self.task_name}" -Confirm:$false -ErrorAction SilentlyContinue
Register-ScheduledTask -TaskName "{self.task_name}" -InputObject $task | Out-Null
Write-Output "registered"
"""
        r = self._powershell(script)
        if r.returncode == 0:
            ok(f"Task Scheduler: {self.task_name} registered")
        else:
            fail(f"Register-ScheduledTask failed: {r.stderr.strip()}")

    def uninstall(self) -> None:
        r = self._powershell(f'Unregister-ScheduledTask -TaskName "{self.task_name}" -Confirm:$false')
        if r.returncode == 0:
            ok(f"Task Scheduler: {self.task_name} unregistered")
        else:
            info(f"task already absent: {self.task_name}")

    def start(self) -> None:
        self._powershell(f'Start-ScheduledTask -TaskName "{self.task_name}"')
        ok(f"started {self.task_name}")

    def stop(self) -> None:
        self._powershell(f'Stop-ScheduledTask -TaskName "{self.task_name}"')
        ok(f"stopped {self.task_name}")

    def status(self) -> str:
        r = self._powershell(f'(Get-ScheduledTask -TaskName "{self.task_name}" -ErrorAction SilentlyContinue).State')
        s = r.stdout.strip()
        if not s:
            return "not-installed"
        return "running" if s.lower() == "running" else "stopped"

def manager() -> ServiceManager:
    o = detect_os()
    if o == "macos":   return LaunchdManager()
    if o == "linux":   return SystemdManager()
    if o == "windows": return TaskSchedulerManager()
    raise SystemExit(f"unsupported OS: {o}")

# ----------------------------------------------------------------------------
# Tick (one-shot) — calls existing learning/tick.sh
# ----------------------------------------------------------------------------

def run_tick_once() -> int:
    tick_script = CLAUDE_HOME / "learning" / "tick.sh"
    if not tick_script.exists():
        fail(f"tick.sh not found: {tick_script}")
        return 1
    r = subprocess.run(["bash", str(tick_script)])
    return r.returncode

# ----------------------------------------------------------------------------
# Telegram notifier (opt-in)
# ----------------------------------------------------------------------------

def _force_ipv4_once() -> None:
    """Monkey-patch socket.getaddrinfo to skip IPv6 results.

    Some networks (Korean ISPs in particular) report IPv6 routes that
    immediately fail with 'No route to host' (errno 65), causing urllib
    to waste time before falling back to IPv4. Skipping IPv6 entirely
    for outbound HTTP makes Telegram polling reliable.
    Idempotent: only patches once per process.
    """
    import socket as _socket
    if getattr(_socket, '_we_forge_ipv4_only', False):
        return
    _orig_gai = _socket.getaddrinfo
    def _ipv4_only_gai(host, *args, **kwargs):
        results = _orig_gai(host, *args, **kwargs)
        ipv4 = [r for r in results if r[0] == _socket.AF_INET]
        return ipv4 if ipv4 else results
    _socket.getaddrinfo = _ipv4_only_gai
    _socket._we_forge_ipv4_only = True


class TelegramNotifier:
    """Minimal Telegram Bot API client using stdlib urllib.

    Activates only when both token and chat_id are configured.
    Sends notification messages on key events; optionally polls for incoming
    /commands in daemon mode.

    Resilience: forces IPv4 (avoids dead IPv6 routes) and retries with
    short timeouts (Korean ISPs sometimes throttle Telegram).
    """

    def __init__(self, token: str, chat_id: str) -> None:
        _force_ipv4_once()
        self.token   = token
        self.chat_id = chat_id
        self.api     = f"https://api.telegram.org/bot{token}"
        self._last_update_id = 0

    def send(self, text: str, html: bool = False) -> bool:
        """Send a message. Default: plain text (always works, never 400s).
        html=True only for senders that pre-formatted with <b>/<code>/<pre>
        and escaped user content via html.escape().

        Retries up to 3 times with short timeouts to handle the intermittent
        Telegram API throttling common on some networks (esp. Korean ISPs)."""
        import urllib.parse, urllib.request, time as _time
        params = {
            "chat_id": self.chat_id,
            "text":    text[:4000],
        }
        if html:
            params["parse_mode"] = "HTML"
        data = urllib.parse.urlencode(params).encode()
        last_err = None
        for attempt in range(3):
            try:
                req = urllib.request.Request(f"{self.api}/sendMessage", data=data)
                with urllib.request.urlopen(req, timeout=8) as resp:
                    return resp.status == 200
            except Exception as e:
                last_err = e
                if attempt < 2:
                    _time.sleep(1.5 * (attempt + 1))  # 1.5s, 3s backoff
        warn(f"telegram send failed after 3 attempts: {last_err}")
        # Fallback: retry without parse_mode if HTML parse failed (single try)
        if html:
            try:
                plain = urllib.parse.urlencode({"chat_id": self.chat_id, "text": text[:4000]}).encode()
                req2  = urllib.request.Request(f"{self.api}/sendMessage", data=plain)
                with urllib.request.urlopen(req2, timeout=8) as resp:
                    return resp.status == 200
            except Exception as e2:
                warn(f"telegram plain-text retry also failed: {e2}")
        return False

    def poll(self, timeout: int = 25) -> list[dict]:
        """Long-poll for /command updates. Returns list of update dicts."""
        import urllib.parse, urllib.request, urllib.error, time as _time
        # Throttle if a previous call returned 409 Conflict (another daemon is
        # polling the same bot token from another PC). Avoid hammering the API
        # and leave room for the other instance to finish its long-poll.
        if hasattr(self, '_conflict_backoff_until'):
            now = _time.time()
            if now < self._conflict_backoff_until:
                _time.sleep(min(5, self._conflict_backoff_until - now))
                return []
        params = {
            "offset":          self._last_update_id + 1,
            "timeout":         timeout,
            "allowed_updates": '["message"]',
        }
        url = f"{self.api}/getUpdates?{urllib.parse.urlencode(params)}"
        try:
            with urllib.request.urlopen(url, timeout=timeout + 5) as resp:
                data = json.loads(resp.read().decode())
            updates = data.get("result", [])
            for u in updates:
                if u.get("update_id", 0) > self._last_update_id:
                    self._last_update_id = u["update_id"]
            # Successful poll → clear any prior backoff
            if hasattr(self, '_conflict_backoff_until'):
                delattr(self, '_conflict_backoff_until')
            return updates
        except urllib.error.HTTPError as e:
            if e.code == 409:
                # Another daemon is polling the same bot. Back off 60s.
                self._conflict_backoff_until = _time.time() + 60
                if not getattr(self, '_conflict_warned', False):
                    warn("telegram poll: HTTP 409 Conflict — another we-forge daemon "
                         "is polling the same bot token (check other PCs). "
                         "Backing off 60s; this PC will not receive bot commands "
                         "until the other daemon stops or its token changes.")
                    self._conflict_warned = True
                return []
            warn(f"telegram poll failed: HTTP {e.code} {e.reason}")
            return []
        except Exception as e:
            warn(f"telegram poll failed: {e}")
            return []

    def handle_command(self, cmd: str) -> str:
        """Dispatch /commands. Returns response text."""
        raw = cmd.strip()
        head = raw.split()[0].lower().split("@")[0] if raw else ""
        rest = raw[len(head):].strip()
        cmd = head
        if cmd in ("/skill_report", "/report"):
            return self._cmd_report()
        if cmd in ("/dashboard", "/dash"):
            return self._cmd_dashboard()
        if cmd in ("/last_tick", "/last"):
            return self._cmd_last_tick()
        if cmd in ("/status", "/health"):
            return self._cmd_status()
        if cmd in ("/ecc_trace", "/ecc"):
            return self._cmd_ecc_trace()
        if cmd in ("/interval",):
            return self._cmd_interval()
        if cmd in ("/set_interval", "/setinterval"):
            return self._cmd_set_interval(rest)
        if cmd in ("/help", "/start"):
            return (
                "we-forge 봇 명령어 안내\n"
                "══════════════════════════════\n"
                "\n"
                "▸ /status\n"
                "  서비스 가동 상태 확인\n"
                "  (running/stopped, scheduled/daemon, telegram on/off)\n"
                "\n"
                "▸ /skill_report\n"
                "  학습 KPI 요약\n"
                "  - 누적 events / patterns / queue / ledger\n"
                "  - ECC_MATCH 비율 (마켓플레이스 활용도)\n"
                "  - TOP 5 자주 하는 패턴\n"
                "\n"
                "▸ /last_tick\n"
                "  최근 tick(학습 사이클) 로그 마지막 15줄\n"
                "  - tick begin/end, normalize 결과, claude agent 호출 등\n"
                "\n"
                "▸ /ecc_trace\n"
                "  ECC 마켓플레이스 스킬 사용 통계\n"
                "  - 어떤 ECC 스킬을 몇 번 활용했는지 누적\n"
                "  - we-forge 의 핵심 KPI\n"
                "\n"
                "▸ /dashboard\n"
                "  웹 대시보드 접속 안내\n"
                "  - http://127.0.0.1:8765 (KPI + 차트 시각화)\n"
                "  - 또는 we-forgectl tui (터미널 인터페이스)\n"
                "\n"
                "▸ /interval\n"
                "  학습 + 알림 주기 조회\n"
                "  - 현재 cadence (분/초), 기본값 사용 여부\n"
                "\n"
                "▸ /set_interval <분>\n"
                "  학습 + 알림 주기 설정 (1 ~ 1440)\n"
                "  - 예: /set_interval 30 → 30분마다\n"
                "  - 다음 daemon 사이클부터 자동 적용 (재시작 불필요)\n"
                "\n"
                "▸ /help\n"
                "  이 도움말 (지금 보고 있는 화면)\n"
                "\n"
                "──────────────────────────────\n"
                "세션 인식 안 될 때 (수동 등록)\n"
                "  Claude Code 세션 내부에서:\n"
                "  ! we-forgectl ping\n"
                "  ! we-forgectl ping <라벨>   (예: ! we-forgectl ping work)\n"
                "  → /status 에서 해당 세션이 표시됨\n"
                "\n"
                "──────────────────────────────\n"
                "we-forge 는 무엇인가\n"
                "  · Claude Code 위에서 24/7 패턴 학습 데몬\n"
                "  · 사용자 작업을 관찰하고 ECC 마켓플레이스 스킬과 매칭\n"
                "  · 매칭되는 스킬이 있으면 추천, 없으면 신규 합성\n"
                "  · ~/.claude/skills/learned/ 에 자동 저장\n"
                "\n"
                "더 자세히는 dashboard 또는 we-forgectl tui 참고하세요."
            )
        return f"unknown command: {cmd}\nsend /help for the full list"

    def _cmd_report(self) -> str:
        # Locate dashboard.py. Search order:
        #   1. ~/.claude/dashboard/dashboard.py — primary install location
        #      (install.sh deploys here, works on every PC)
        #   2. <we-forgectl_dir>/../dashboard/dashboard.py — repo dev mode
        #   3. ~/we-forge/dashboard/dashboard.py — common manual-clone path
        # No user-specific absolute paths anywhere.
        candidates = [
            CLAUDE_HOME / "dashboard" / "dashboard.py",
            Path(__file__).resolve().parent.parent / "dashboard" / "dashboard.py",
            Path.home() / "we-forge" / "dashboard" / "dashboard.py",
        ]
        dashboard_path = next((p for p in candidates if p.exists()), None)
        if not dashboard_path:
            return f"report failed: dashboard.py not found in {[str(p) for p in candidates]}"
        try:
            from importlib.util import spec_from_file_location, module_from_spec
            spec = spec_from_file_location("dashboard", str(dashboard_path))
            mod = module_from_spec(spec); spec.loader.exec_module(mod)
            k = mod.compute_kpis()
            lines = ["we-forge skill report", "═" * 30]
            lines.append(f"events: {k['totals']['events']}  patterns: {k['totals']['patterns']}")
            lines.append(f"queue: {k['totals']['queue']}  ledger: {k['totals']['ledger']}")
            lines.append(f"ECC_MATCH ratio: {k['ecc_match_ratio']*100:.1f}%")
            lines.append("")
            lines.append("top 5 patterns:")
            for pat, n in k["top_patterns"][:5]:
                lines.append(f"  {n:>4}  {pat}")
            return "\n".join(lines)
        except Exception as e:
            return f"report failed: {e}"

    def _cmd_dashboard(self) -> str:
        return ("dashboard: we-forgectl dashboard (web on http://127.0.0.1:8765)\n"
                "or: we-forgectl tui (terminal)")

    def _cmd_last_tick(self) -> str:
        log = CLAUDE_HOME / "learning/data/tick.log"
        if not log.exists():
            return "no tick.log yet"
        lines = log.read_text(errors="replace").splitlines()[-15:]
        return "last tick log:\n" + "\n".join(lines)

    def _cmd_status(self) -> str:
        import datetime as _dt
        m = manager()
        s = m.status()
        cfg = load_config()
        sec = get_daemon_interval_seconds()
        next_ts = next_aligned_tick_time(sec, time.time())
        next_local = _dt.datetime.fromtimestamp(next_ts).strftime("%m/%d %H:%M")

        head = (
            f"we-forge status: {s}\n"
            f"mode: {cfg.get('mode', 'scheduled')}\n"
            f"interval: {sec // 60} min  (next tick: {next_local})\n"
            f"telegram: {'enabled' if cfg.get('telegram_enabled') else 'disabled'}\n"
        )

        # Active Claude Code sessions (transcript mtime in last 60min)
        sessions_block = self._format_active_sessions(window_min=60, max_show=10)
        return head + "\n" + sessions_block

    @staticmethod
    def _decode_project_path(encoded: str) -> str:
        return decode_project_path(encoded)

    def _format_active_sessions(self, window_min: int = 60, max_show: int = 10) -> str:
        return format_active_sessions(window_min=window_min, max_show=max_show)

    def _cmd_interval(self) -> str:
        import datetime as _dt
        sec = get_daemon_interval_seconds()
        cfg = load_config()
        explicit = cfg.get("interval_minutes")
        line2 = (f"  설정값: {explicit}분  (config.json)" if explicit
                 else f"  설정값: 미지정 → 기본값 {DAEMON_INTERVAL_DEFAULT_MIN}분 사용 중")
        next_ts = next_aligned_tick_time(sec, time.time())
        next_local = _dt.datetime.fromtimestamp(next_ts).strftime("%Y-%m-%d %H:%M")
        return ("we-forge cadence\n"
                "══════════════════════════════\n"
                f"  현재: {sec // 60}분  ({sec}초)\n"
                f"{line2}\n"
                f"  다음 발화: {next_local}  (로컬 00:00 기준 정렬)\n"
                "  의미: tick(학습) + telegram 알림이 같은 주기로 발화\n\n"
                "변경: /set_interval <분>  (예: /set_interval 30)\n"
                "범위: 1 ~ 1440 (1분 ~ 24시간)\n"
                "참고: 모든 슬롯은 자정(00:00) 기준 정렬됨")

    def _cmd_set_interval(self, arg: str) -> str:
        if not arg:
            return ("사용법: /set_interval <분>\n"
                    "예: /set_interval 30   (30분마다)\n"
                    "    /set_interval 60   (1시간마다, 기본값)\n"
                    "    /set_interval 5    (5분마다, 빈번)\n"
                    "범위: 1 ~ 1440 (1분 ~ 24시간)\n"
                    "현재값 조회: /interval")
        try:
            minutes = int(arg.split()[0])
        except (ValueError, IndexError):
            return f"잘못된 입력: '{arg}'\n정수(분)를 입력하세요. 예: /set_interval 30"
        if minutes < 1 or minutes > 1440:
            return f"범위 초과: {minutes}분\n허용 범위: 1 ~ 1440 (1분 ~ 24시간)"
        cfg = load_config()
        old = cfg.get("interval_minutes") or DAEMON_INTERVAL_DEFAULT_MIN
        cfg["interval_minutes"] = minutes
        save_config(cfg)
        # Reset throttle state so the new cadence applies on next tick.
        try:
            (WE_FORGE_HOME / "last_telegram_sent_at").unlink(missing_ok=True)
            (WE_FORGE_HOME / "telegram_pending.jsonl").unlink(missing_ok=True)
        except OSError:
            pass
        cmd_ecc_log("enterprise-agent-ops",
                    f"interval changed via telegram bot ({old}→{minutes} min)",
                    invoker="bot")
        return ("⚙️ interval 변경 완료\n"
                "══════════════════════════════\n"
                f"  이전: {old}분\n"
                f"  현재: {minutes}분\n"
                f"  적용: 다음 daemon iteration (최대 60초 내, 재시작 불필요)\n"
                f"  효과: tick {minutes}분마다 · telegram 알림 {minutes}분마다")

    def _cmd_ecc_trace(self) -> str:
        if not ECC_TRACE_FILE.exists():
            return "no ECC trace yet — agent will populate as it leverages skills"
        from collections import Counter
        entries = []
        with ECC_TRACE_FILE.open(encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if line:
                    try:
                        entries.append(json.loads(line))
                    except json.JSONDecodeError:
                        pass
        counter = Counter(e.get("skill", "?") for e in entries)
        lines = [f"ECC skill usage ({len(entries)} records)", "═" * 30]
        for skill, n in counter.most_common(15):
            lines.append(f"  {n:>3}  {skill}")
        return "\n".join(lines)

def get_notifier():
    cfg = load_config()
    if not cfg.get("telegram_enabled"):
        return None
    token   = cfg.get("telegram_token") or os.environ.get("WE_FORGE_TELEGRAM_TOKEN", "")
    chat_id = cfg.get("telegram_chat_id") or os.environ.get("WE_FORGE_TELEGRAM_CHAT_ID", "")
    if not token or not chat_id:
        return None
    return TelegramNotifier(token, chat_id)

# ----------------------------------------------------------------------------
# Daemon loop
# ----------------------------------------------------------------------------

def daemon_loop() -> int:
    """Long-running loop: tick every WE_FORGE_DAEMON_INTERVAL seconds, plus
    optional Telegram bot polling (if enabled).

    Critical: when stdout is redirected to a file (launchd / systemd), Python's
    print() is BLOCK-buffered, not line-buffered. Reconfigure to line buffering
    so daemon.log shows progress in real time.
    """
    try:
        sys.stdout.reconfigure(line_buffering=True)
        sys.stderr.reconfigure(line_buffering=True)
    except (AttributeError, OSError):
        pass

    WE_FORGE_HOME.mkdir(parents=True, exist_ok=True)
    DAEMON_PID.write_text(str(os.getpid()), encoding="utf-8")
    initial_interval = get_daemon_interval_seconds()
    next_tick_at = next_aligned_tick_time(initial_interval, time.time())
    import datetime as _dt
    next_local = _dt.datetime.fromtimestamp(next_tick_at).strftime("%Y-%m-%d %H:%M %Z")
    print(f"[{now_iso()}] we-forge daemon starting (pid={os.getpid()}, "
          f"interval={initial_interval}s = {initial_interval//60}min, "
          f"next aligned tick: {next_local.strip()})")
    notifier = get_notifier()
    if notifier:
        print(f"[{now_iso()}] Telegram notifier enabled")
        notifier.send("🔧 we-forge daemon started")

    last_interval = initial_interval

    try:
        while True:
            now = time.time()
            # Hot-reload: re-read config every iteration so `set-interval`
            # takes effect without daemon restart.
            current_interval = get_daemon_interval_seconds()
            # If interval changed via set-interval, re-anchor next slot from now.
            if current_interval != last_interval:
                next_tick_at = next_aligned_tick_time(current_interval, now)
                last_interval = current_interval
                next_local = _dt.datetime.fromtimestamp(next_tick_at).strftime("%H:%M")
                print(f"[{now_iso()}] interval changed → {current_interval//60}min, "
                      f"next aligned tick: {next_local}")

            if now >= next_tick_at:
                print(f"[{now_iso()}] tick begin (aligned slot)")
                import threading
                tick_thread = threading.Thread(
                    target=lambda: print(f"[{now_iso()}] tick end (rc={run_tick_once()})"),
                    daemon=True,
                )
                tick_thread.start()
                # Schedule next aligned slot strictly after now.
                next_tick_at = next_aligned_tick_time(current_interval, time.time())
                next_local = _dt.datetime.fromtimestamp(next_tick_at).strftime("%H:%M")
                print(f"[{now_iso()}] next aligned tick: {next_local}")

            if notifier:
                updates = notifier.poll(timeout=25)
                for u in updates:
                    msg = u.get("message", {})
                    text = (msg.get("text") or "").strip()
                    chat_id = str(msg.get("chat", {}).get("id", ""))
                    if chat_id != notifier.chat_id:
                        continue
                    if text.startswith("/"):
                        print(f"[{now_iso()}] handling command: {text}")
                        reply = notifier.handle_command(text)
                        notifier.send(reply)
            else:
                sleep_for = max(1, int(next_tick_at - time.time()))
                time.sleep(min(60, sleep_for))
    except KeyboardInterrupt:
        print(f"[{now_iso()}] daemon stopped (KeyboardInterrupt)")
        if notifier:
            notifier.send("🔧 we-forge daemon stopped")
        return 0
    except Exception as e:
        print(f"[{now_iso()}] daemon crashed: {e}", file=sys.stderr)
        if notifier:
            notifier.send(f"⚠️ we-forge daemon crashed: {e}")
        return 1
    finally:
        if DAEMON_PID.exists():
            DAEMON_PID.unlink()

# ----------------------------------------------------------------------------
# TUI (rich)
# ----------------------------------------------------------------------------

def tui() -> int:
    try:
        from rich.console   import Console
        from rich.panel     import Panel
        from rich.table     import Table
        from rich.prompt    import Prompt
    except ImportError:
        warn("rich not installed; falling back to plain status")
        print()
        return cmd_status()

    console = Console()
    while True:
        os.system("clear" if os.name != "nt" else "cls")
        m   = manager()
        s   = m.status()
        cfg = load_config()
        status_color = {"running":"green","stopped":"yellow","not-installed":"red"}.get(s, "white")
        t = Table(show_header=False, box=None, padding=(0, 1))
        t.add_column(style="dim"); t.add_column(style="bold")
        t.add_row("status",     f"[{status_color}]{s}[/{status_color}]")
        t.add_row("mode",       cfg.get("mode", "scheduled"))
        t.add_row("telegram",   "enabled" if cfg.get("telegram_enabled") else "disabled")
        t.add_row("CLAUDE_HOME", str(CLAUDE_HOME))
        console.print(Panel(t, title="we-forge control", border_style="cyan"))
        console.print()
        console.print("  [s] Start service       [t] Stop service       [r] Restart")
        console.print("  [i] Install             [u] Uninstall          [v] Verify")
        console.print("  [l] Show recent ticks   [m] Open dashboard     [n] Toggle Telegram")
        console.print("  [d] Run tick now        [q] Quit")
        console.print()
        choice = Prompt.ask("choice", default="q").strip().lower()
        try:
            if choice == "s":   m.start()
            elif choice == "t": m.stop()
            elif choice == "r": m.restart()
            elif choice == "i":
                cmd_install(False, False)
            elif choice == "u":
                if Prompt.ask("are you sure? (yes/no)", default="no") == "yes":
                    cmd_uninstall(deep=False)
            elif choice == "v": cmd_doctor()
            elif choice == "l": cmd_logs(20)
            elif choice == "m":
                step("opening dashboard at http://127.0.0.1:8765")
                cmd_dashboard()
            elif choice == "n": cmd_toggle_telegram()
            elif choice == "d":
                step("running tick now...")
                rc = run_tick_once()
                ok(f"tick exit code: {rc}")
            elif choice == "q":
                return 0
            else:
                warn(f"unknown choice: {choice}")
        except Exception as e:
            fail(str(e))
        Prompt.ask("press enter to continue", default="")

