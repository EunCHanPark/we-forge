# Subcommand implementations
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Session detection — module-level helpers shared by CLI and Telegram bot
# ----------------------------------------------------------------------------

def decode_project_path(encoded: str) -> str:
    """Decode Claude Code's encoded project dir name back to a filesystem path.

    Claude Code encodes the project root by prepending '-' and replacing every
    '/' and '.' with '-'.  Double dashes ('--') therefore represent '/.' (a
    hidden directory component like '.claude').  We resolve greedily O(n)
    using filesystem existence checks.
    """
    stripped = encoded.lstrip("-")

    # Fast-path 1: direct slash substitution (paths with no dots or dashes)
    simple = "/" + stripped.replace("-", "/")
    if os.path.exists(simple):
        return simple

    # Fast-path 2: handle '--' as '/.' before single-dash replacement
    with_dot = "/" + stripped.replace("--", "/.").replace("-", "/")
    if os.path.exists(with_dot):
        return with_dot

    # Greedy walk: split on '-', treating empty segments (from '--') as '.'
    segments: list[str] = []
    i = 0
    raw = stripped.split("-")
    while i < len(raw):
        if raw[i] == "" and i + 1 < len(raw):
            # '--' → the next segment is a dot-prefixed name
            segments.append("." + raw[i + 1])
            i += 2
        else:
            if raw[i]:
                segments.append(raw[i])
            i += 1

    if not segments:
        return with_dot or simple

    path = "/" + segments[0]
    for seg in segments[1:]:
        slash_try = path + "/" + seg
        dash_try  = path + "-" + seg
        if os.path.exists(slash_try):
            path = slash_try
        elif os.path.exists(dash_try):
            path = dash_try
        else:
            path = slash_try
    return path


HEARTBEAT_DIR = WE_FORGE_HOME / "heartbeats"


def cmd_ping(label: str = "") -> int:
    """Register the current Claude Code session with a heartbeat file.

    Run `! we-forgectl ping` (or `! we-forgectl ping mylabel`) from inside any
    Claude Code session.  we-forge will then list this session even if the
    transcript file hasn't been written recently.

    Heartbeat files live at ~/.we-forge/heartbeats/<pid>.json and expire after
    the session window (default 60 min).
    """
    HEARTBEAT_DIR.mkdir(parents=True, exist_ok=True)
    cwd = os.getcwd()
    pid = os.getpid()
    record = {
        "ts":    now_iso(),
        "epoch": time.time(),
        "cwd":   cwd,
        "pid":   pid,
        "label": label or "",
    }
    hb_file = HEARTBEAT_DIR / f"{pid}.json"
    hb_file.write_text(json.dumps(record, ensure_ascii=False), encoding="utf-8")
    print("================================================================")
    print("✅  we-forge attached to this session")
    print(f"    cwd:   {cwd}")
    print(f"    pid:   {pid}")
    if label:
        print(f"    label: {label}")
    print("================================================================")
    info("we-forgectl sessions  — to verify this session is visible")
    return 0


def _read_heartbeats(cutoff: float) -> list[tuple[float, str, str]]:
    """Return (mtime, label, cwd) for heartbeats newer than *cutoff*."""
    rows: list[tuple[float, str, str]] = []
    if not HEARTBEAT_DIR.exists():
        return rows
    for hb in HEARTBEAT_DIR.glob("*.json"):
        try:
            data  = json.loads(hb.read_text(encoding="utf-8"))
            epoch = float(data.get("epoch") or hb.stat().st_mtime)
        except (OSError, ValueError, json.JSONDecodeError):
            continue
        if epoch < cutoff:
            try:
                hb.unlink()   # prune expired heartbeat
            except OSError:
                pass
            continue
        cwd   = data.get("cwd") or "?"
        label = data.get("label") or f"pid={data.get('pid','?')}"
        rows.append((epoch, label, cwd))
    return rows


def format_active_sessions(window_min: int = 60, max_show: int = 10) -> str:
    """List Claude Code sessions detected via transcript mtime OR heartbeat ping."""
    import datetime as _dt
    now    = time.time()
    cutoff = now - window_min * 60

    # --- transcript-based detection ---
    rows: list[tuple[float, str, str]] = []
    projects = CLAUDE_HOME / "projects"
    if projects.exists():
        for proj in projects.iterdir():
            if not proj.is_dir():
                continue
            decoded = decode_project_path(proj.name)
            for tx in proj.glob("*.jsonl"):
                try:
                    mtime = tx.stat().st_mtime
                except OSError:
                    continue
                if mtime < cutoff:
                    continue
                rows.append((mtime, tx.stem[:8], decoded))

    # --- heartbeat-based detection (manual ping fallback) ---
    seen_cwds = {r[2] for r in rows}
    for epoch, label, cwd in _read_heartbeats(cutoff):
        if cwd not in seen_cwds:
            rows.append((epoch, f"ping:{label}", cwd))
            seen_cwds.add(cwd)

    rows.sort(reverse=True)
    if not rows:
        return (
            f"active sessions (last {window_min}min): (none — all idle)\n"
            f"  tip: run  ! we-forgectl ping  from inside a session to register it"
        )
    lines = [f"active sessions (last {window_min}min, {len(rows)} total):"]
    for mtime, sid, path in rows[:max_show]:
        age_min = int((now - mtime) / 60)
        mark    = "⚡" if age_min < 5 else "🕐" if age_min < 30 else "💤"
        ts_str  = _dt.datetime.fromtimestamp(mtime).strftime("%H:%M")
        short   = path if len(path) <= 45 else "…" + path[-44:]
        lines.append(f"  {mark} {sid}  {ts_str} ({age_min}m)  {short}")
    if len(rows) > max_show:
        lines.append(f"  … ({len(rows) - max_show} more)")
    lines.append("  (run  ! we-forgectl ping  to register a session not shown above)")
    return "\n".join(lines)


def cmd_sessions(window_min: int = 60) -> int:
    """Print active Claude Code sessions detected via transcript file activity."""
    print(format_active_sessions(window_min=window_min, max_show=20))
    return 0


# ----------------------------------------------------------------------------
# ECC trace — record + report which ECC marketplace skills are used
# ----------------------------------------------------------------------------

def cmd_ecc_log(
    skill: str,
    reason: str,
    invoker: str = "cli",
    match_method: str = "",
    match_score=None,
    decision_latency_ms=None,
) -> int:
    """Append one ECC usage record to ~/.we-forge/ecc-trace.jsonl.

    Required: skill, reason. Optional metadata for ROI analytics:
      match_method        — "manual" | "scored" | "exact-slug" | "keyword"
      match_score         — int (pattern-detector dedupe score, 0-10)
      decision_latency_ms — int (time spent deciding to leverage this skill)

    Optional fields are omitted from the record when not provided so the
    schema stays compact for trivial CLI logs.
    """
    if not skill:
        fail("skill name required")
        return 2
    WE_FORGE_HOME.mkdir(parents=True, exist_ok=True)
    record: dict = {
        "ts":      now_iso(),
        "skill":   skill.strip(),
        "reason":  reason.strip()[:200],
        "invoker": invoker,
    }
    if match_method:
        record["match_method"] = match_method
    if match_score is not None:
        record["match_score"] = int(match_score)
    if decision_latency_ms is not None:
        record["decision_latency_ms"] = int(decision_latency_ms)
    with ECC_TRACE_FILE.open("a", encoding="utf-8") as f:
        f.write(json.dumps(record, ensure_ascii=False) + "\n")
    ok(f"logged: {skill}")
    return 0

def cmd_audit(top_n: int = 30) -> int:
    """Audit whether high-frequency patterns were correctly handled.

    Cross-references patterns.jsonl with ledger.jsonl to surface:
      - patterns with high count + ECC_MATCH → did the matched skill
        genuinely cover the user's workflow? (manual review needed)
      - patterns with high count + DROP      → was the primitive filter
        too aggressive?
      - patterns with high count + no ledger entry → missed pipeline?

    Goal: distinguish "ECC genuinely covers it" from "we wrongly skipped
    something the user actually needs learned."
    """
    import re as _re
    learn = Path.home() / ".claude" / "learning" / "data"
    pat_path = learn / "patterns.jsonl"
    led_path = learn / "ledger.jsonl"
    rej_path = learn / "rejected.txt"
    if not pat_path.exists():
        warn(f"no patterns yet: {pat_path}")
        return 0
    rejected_set: set[str] = set()
    if rej_path.exists():
        rejected_set = {ln.strip() for ln in rej_path.read_text(encoding="utf-8").splitlines()
                        if ln.strip()}
    patterns = []
    with pat_path.open(encoding="utf-8") as f:
        for ln in f:
            try:
                patterns.append(json.loads(ln))
            except Exception:
                pass
    # Build slug → list of ledger decisions
    slug_to_decisions: dict[str, list[dict]] = {}
    if led_path.exists():
        with led_path.open(encoding="utf-8") as f:
            for ln in f:
                try:
                    d = json.loads(ln)
                    s = d.get("slug", "")
                    if s:
                        slug_to_decisions.setdefault(s, []).append(d)
                except Exception:
                    pass

    def _slug(p: str) -> str:
        s = _re.sub(r"[^A-Za-z0-9]+", "-", p.lower()).strip("-")
        return (s[:60] or "pattern").strip("-") or "pattern"

    rows: list[tuple[int, str, str, str, str]] = []
    for p in patterns:
        cnt = p.get("count", 0)
        sids = len(p.get("sample_session_ids", []))
        if cnt < 3 or sids < 3:
            continue
        pat = p.get("pattern", "")
        slug = _slug(pat)
        decisions = slug_to_decisions.get(slug, [])
        if decisions:
            last = decisions[-1]
            verdict = last.get("decision", "?")
            reason = (last.get("reason") or "")[:60]
        elif pat in rejected_set:
            verdict = "REJECTED"
            reason = "in rejected.txt (skipped from queue)"
        else:
            verdict = "no-ledger"
            reason = "(never reached ledger — investigate)"
        rows.append((cnt, verdict, pat[:60], reason, slug))
    rows.sort(key=lambda r: -r[0])
    print(f"==> audit: top {top_n} patterns (count >= 3, distinct sessions >= 3)")
    print(f"{'count':>6}  {'verdict':<12}  {'pattern':<60}  reason")
    print("-" * 110)
    for cnt, verdict, pat, reason, slug in rows[:top_n]:
        print(f"{cnt:>6}  {verdict:<12}  {pat:<60}  {reason}")
    counts: dict = {}
    for r in rows:
        counts[r[1]] = counts.get(r[1], 0) + 1
    print()
    print("verdict breakdown (qualifying patterns):", counts)
    print()
    print("Interpretation:")
    print("  - High count + ECC_MATCH: verify the matched skill genuinely fits.")
    print("  - High count + DROP:      verify the primitive filter wasn't over-eager.")
    print("  - High count + no-ledger: pipeline gap — should have been processed.")
    return 0


def cmd_ecc_quality(score_threshold: int = 3) -> int:
    """Inspect ECC_MATCH match_score distribution; flag low-confidence matches.

    Surfaces entries below `score_threshold` as candidates for REVISE
    downgrade — they were classified ECC_MATCH but the dedupe scoring
    is weak enough that the matched skill may not actually cover the
    user's workflow.
    """
    led_path = Path.home() / ".claude" / "learning" / "data" / "ledger.jsonl"
    if not led_path.exists():
        warn(f"no ledger: {led_path}")
        return 0
    from collections import Counter
    score_dist: Counter = Counter()
    flagged: list = []
    skill_counts: Counter = Counter()
    with led_path.open(encoding="utf-8") as f:
        for ln in f:
            try:
                d = json.loads(ln)
            except Exception:
                continue
            if d.get("decision") != "ECC_MATCH":
                continue
            score = d.get("match_score")
            if score is None:
                score_dist["unknown"] += 1
                continue
            score_dist[int(score)] += 1
            skill_counts[d.get("ecc_skill", "?")] += 1
            if int(score) < score_threshold:
                flagged.append(d)
    print(f"==> ECC_MATCH match_score distribution (threshold={score_threshold})")
    for s in sorted(score_dist.keys(),
                    key=lambda k: (-1 if k == "unknown" else int(k))):
        marker = " ⚠️" if isinstance(s, int) and s < score_threshold else ""
        print(f"  score {str(s):<8} {score_dist[s]:>4}{marker}")
    print()
    print(f"==> top matched ECC skills (top 10)")
    for skill, n in skill_counts.most_common(10):
        print(f"  {n:>4}  {skill}")
    print()
    if flagged:
        print(f"==> ⚠️  {len(flagged)} entries below score_threshold "
              f"(REVISE downgrade candidates)")
        for d in flagged[:15]:
            print(f"  {d.get('slug',''):<35} score={d.get('match_score','?')} "
                  f"ecc_skill={d.get('ecc_skill','?')}")
    else:
        print(f"==> all ECC_MATCH entries score >= {score_threshold} ✓")
    return 0


def cmd_ecc_trace(last_n: int = 20, group: bool = False) -> int:
    """Show ECC usage history, newest first.

    --group displays counts per skill instead of the timeline.
    """
    if not ECC_TRACE_FILE.exists():
        warn(f"no ECC trace yet: {ECC_TRACE_FILE}")
        info("the we-forge agent (or CLI) calls 'we-forgectl ecc-log <skill> <reason>'")
        info("each time it leverages an ECC marketplace skill.")
        return 0
    entries = []
    with ECC_TRACE_FILE.open(encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                entries.append(json.loads(line))
            except json.JSONDecodeError:
                pass
    if group:
        from collections import Counter
        c = Counter(e.get("skill", "?") for e in entries)
        step(f"ECC skill usage (totals across {len(entries)} records)")
        for skill, n in c.most_common():
            print(f"  {n:>4}  {skill}")
        return 0
    step(f"ECC trace (last {last_n} of {len(entries)})")
    for e in entries[-last_n:]:
        ts     = e.get("ts", "?")
        skill  = e.get("skill", "?")
        reason = e.get("reason", "")[:80]
        invk   = e.get("invoker", "?")
        print(f"  {ts}  {DIM}[{invk}]{RESET}  {GREEN}{skill}{RESET}  {reason}")
    return 0

# ----------------------------------------------------------------------------

def cmd_install(enable_telegram: bool, daemon: bool) -> int:
    """One-shot install: register service, optionally enable Telegram."""
    step(f"we-forgectl install (daemon={daemon}, telegram={enable_telegram})")

    if enable_telegram:
        daemon = True

    m = manager()
    m.migrate_legacy()

    cfg = load_config()
    cfg.update({
        "mode":          "daemon" if daemon else "scheduled",
        "installed_at":  now_iso(),
        "telegram_enabled": enable_telegram,
    })
    if enable_telegram:
        token   = (os.environ.get("WE_FORGE_TELEGRAM_TOKEN")
                   or input("WE_FORGE_TELEGRAM_TOKEN (from @BotFather): ").strip())
        chat_id = (os.environ.get("WE_FORGE_TELEGRAM_CHAT_ID")
                   or input("WE_FORGE_TELEGRAM_CHAT_ID (your chat id with the bot): ").strip())
        if not token or not chat_id:
            fail("token and chat_id are required when --enable-telegram")
            return 2
        cfg["telegram_token"]   = token
        cfg["telegram_chat_id"] = chat_id
    save_config(cfg)
    ok(f"config: {CONFIG_FILE}")

    m.install(daemon=daemon)
    ok(f"service installed (mode={cfg['mode']})")

    time.sleep(1.5)
    s = m.status()
    if s == "running":
        ok(f"status: {s}")
    else:
        warn(f"status: {s} — check logs")

    print()
    step("we-forge is now installed and " + ("running as daemon" if daemon else "scheduled hourly"))
    print(f"  status:    we-forgectl status")
    print(f"  logs:      we-forgectl logs")
    print(f"  uninstall: we-forgectl uninstall")
    return 0

def cmd_uninstall(deep: bool) -> int:
    """Safe uninstall: backup → remove service → optionally remove data."""
    step("we-forgectl uninstall (safety-guard pattern)")

    BACKUP_DIR.mkdir(parents=True, exist_ok=True)
    snap = BACKUP_DIR / now_iso()
    snap.mkdir()
    if CONFIG_FILE.exists():
        shutil.copy2(CONFIG_FILE, snap / "config.json")
    if (CLAUDE_HOME / "settings.json").exists():
        shutil.copy2(CLAUDE_HOME / "settings.json", snap / "settings.json")
    ok(f"backup: {snap}")

    m = manager()
    try:
        m.stop()
    except Exception as e:
        warn(f"stop: {e}")
    m.uninstall()
    ok("service uninstalled")

    if deep:
        warn("deep uninstall: moving ~/.we-forge/ and ~/.claude/learning/data/ to backup")
        if WE_FORGE_HOME.exists():
            shutil.move(str(WE_FORGE_HOME), str(snap / "we-forge-home"))
            ok(f"~/.we-forge moved to {snap}/we-forge-home")
        data_dir = CLAUDE_HOME / "learning/data"
        if data_dir.exists():
            shutil.move(str(data_dir), str(snap / "learning-data"))
            ok(f"~/.claude/learning/data moved to {snap}/learning-data")

    print()
    step(f"uninstalled. backup at: {snap}")
    print("  to fully remove agent files, also: rm ~/.claude/agents/we-forge.md ~/.claude/agents/{pattern-detector,quality-auditor,skill-synthesizer,monitor-sentinel}.md ~/.claude/commands/{watch-and-learn,skill-report,dashboard}.md")
    return 0

def cmd_status() -> int:
    import datetime as _dt
    m   = manager()
    s   = m.status()
    cfg = load_config()
    interval_sec = get_daemon_interval_seconds()
    next_ts = next_aligned_tick_time(interval_sec, time.time())
    next_local = _dt.datetime.fromtimestamp(next_ts).strftime("%Y-%m-%d %H:%M")
    color = {"running":GREEN, "stopped":YELLOW, "not-installed":RED}.get(s, "")
    print(f"  status:   {color}{s}{RESET}")
    print(f"  mode:     {cfg.get('mode', 'scheduled')}")
    print(f"  interval: {interval_sec // 60} min  ({interval_sec}s — learning + telegram, aligned to 00:00)")
    print(f"  next tick: {next_local}")
    print(f"  telegram: {'enabled' if cfg.get('telegram_enabled') else 'disabled'}")
    print(f"  os:       {detect_os()}{' (WSL)' if is_wsl() else ''}")
    print(f"  config:   {CONFIG_FILE}")
    print()
    print(format_active_sessions(window_min=60, max_show=10))
    return 0 if s == "running" else 1

def cmd_set_interval(minutes: int) -> int:
    """Set the unified tick + telegram cadence (minutes). Hot-reloaded by daemon."""
    if minutes < 1:
        err("interval must be >= 1 minute")
        return 2
    if minutes > 1440:
        err("interval must be <= 1440 minutes (24 hours)")
        return 2
    cfg = load_config()
    old = cfg.get("interval_minutes", DAEMON_INTERVAL_DEFAULT_MIN)
    cfg["interval_minutes"] = minutes
    save_config(cfg)
    ok(f"interval: {old} min → {minutes} min")
    print(f"  config:   {CONFIG_FILE}")
    print(f"  effect:   tick every {minutes} min · telegram notify every {minutes} min")
    print(f"  applies:  next iteration of running daemon (no restart needed — hot-reload)")
    # Also reset telegram throttle state so next tick uses new cadence cleanly.
    last_sent = WE_FORGE_HOME / "last_telegram_sent_at"
    pending   = WE_FORGE_HOME / "telegram_pending.jsonl"
    try:
        if last_sent.exists(): last_sent.unlink()
        if pending.exists():   pending.unlink()
        ok("telegram throttle state reset (will fire on next tick with results)")
    except OSError as e:
        warn(f"telegram throttle reset skipped: {e}")
    try:
        from urllib import request as _req, parse as _parse
        if cfg.get("telegram_enabled") and cfg.get("telegram_token") and cfg.get("telegram_chat_id"):
            payload = _parse.urlencode({
                "chat_id": cfg["telegram_chat_id"],
                "text":    f"⚙️ we-forge interval: {old}min → {minutes}min (hot-reload)",
            }).encode()
            _req.urlopen(
                f"https://api.telegram.org/bot{cfg['telegram_token']}/sendMessage",
                data=payload, timeout=10,
            )
            ok("telegram notified of interval change")
    except Exception as e:
        warn(f"telegram notify skipped: {e}")
    cmd_ecc_log("enterprise-agent-ops",
                f"interval changed via set-interval ({old}→{minutes} min)", invoker="cli")
    return 0

def cmd_logs(n: int) -> int:
    log_candidates = [
        Path.home() / "Library/Logs/we-forge/daemon.log",
        Path(os.environ.get("XDG_STATE_HOME", str(Path.home() / ".local/state"))) / "we-forge/daemon.log",
        CLAUDE_HOME / "learning/data/tick.log",
    ]
    for log in log_candidates:
        if log.exists():
            step(f"tail -n {n} {log}")
            try:
                lines = log.read_text(errors="replace").splitlines()[-n:]
                for line in lines:
                    print(f"  {line}")
            except OSError as e:
                fail(str(e))
            return 0
    warn("no log files found yet")
    return 1

def cmd_dashboard() -> int:
    candidates = [
        Path(__file__).resolve().parent.parent / "dashboard/dashboard.py",
        Path.home() / "we-forge/dashboard/dashboard.py",
    ]
    for d in candidates:
        if d.exists():
            os.execv(sys.executable, [sys.executable, str(d), "--serve"])
    fail("dashboard.py not found")
    return 1

def cmd_toggle_telegram() -> int:
    cfg = load_config()
    enabled = not cfg.get("telegram_enabled", False)
    if enabled:
        token   = (cfg.get("telegram_token") or os.environ.get("WE_FORGE_TELEGRAM_TOKEN")
                   or input("WE_FORGE_TELEGRAM_TOKEN: ").strip())
        chat_id = (cfg.get("telegram_chat_id") or os.environ.get("WE_FORGE_TELEGRAM_CHAT_ID")
                   or input("WE_FORGE_TELEGRAM_CHAT_ID: ").strip())
        if not token or not chat_id:
            fail("token and chat_id required")
            return 2
        cfg.update({"telegram_token": token, "telegram_chat_id": chat_id})
    cfg["telegram_enabled"] = enabled
    save_config(cfg)
    ok(f"telegram: {'enabled' if enabled else 'disabled'}")
    info("re-run 'we-forgectl restart' for daemon to pick up the change")
    return 0

def cmd_notify_test() -> int:
    n = get_notifier()
    if not n:
        fail("telegram not enabled or token/chat_id missing")
        return 2
    if n.send("🔧 we-forge notify-test ping at " + now_iso()):
        ok("test message sent")
        return 0
    return 1

def cmd_doctor() -> int:
    """Diagnose install + dependencies."""
    step("doctor")
    issues = 0
    for tool in ("python3", "bash", "jq"):
        if shutil.which(tool):
            ok(f"{tool}: {shutil.which(tool)}")
        else:
            fail(f"{tool} not in PATH"); issues += 1
    for path, label in [
        (CLAUDE_HOME / "learning/tick.sh", "tick.sh"),
        (CLAUDE_HOME / "agents/we-forge.md", "we-forge agent"),
        (CLAUDE_HOME / "settings.json", "settings.json"),
    ]:
        if path.exists():
            ok(f"{label}: {path}")
        else:
            fail(f"{label} missing: {path}"); issues += 1
    s = manager().status()
    (ok if s == "running" else warn)(f"service: {s}")
    if issues == 0:
        print(f"\n{GREEN}all checks passed.{RESET}")
        return 0
    print(f"\n{RED}{issues} issue(s).{RESET} run `we-forgectl install` to register service.")
    return 1

# ----------------------------------------------------------------------------
# CLI
# ----------------------------------------------------------------------------

def main() -> int:
    p = argparse.ArgumentParser(
        prog="we-forgectl",
        description="we-forge service & operations control")
    sp = p.add_subparsers(dest="cmd")

    p_install = sp.add_parser("install",   help="register the launchd/systemd/Task Scheduler service")
    p_install.add_argument("--enable-telegram", action="store_true",
                           help="opt-in Telegram notifier (forces daemon mode)")
    p_install.add_argument("--daemon", action="store_true",
                           help="install in daemon mode (long-running, restarts on crash)")

    p_uninstall = sp.add_parser("uninstall", help="remove the service (with safety backup)")
    p_uninstall.add_argument("--deep", action="store_true",
                             help="also move ~/.we-forge and learning/data to backup")

    sp.add_parser("start",     help="start the service")
    sp.add_parser("stop",      help="stop the service")
    sp.add_parser("restart",   help="restart the service")
    sp.add_parser("status",    help="show service status")
    sp.add_parser("run",       help="alias of 'daemon' (foreground long-running)")
    sp.add_parser("daemon",    help="long-running loop (called by service manager)")
    sp.add_parser("run-once",  help="run a single tick and exit (called by scheduled mode)")
    sp.add_parser("tui",       help="rich-powered terminal UI")
    sp.add_parser("dashboard", help="launch the web dashboard (delegates to dashboard.py --serve)")
    sp.add_parser("notify-test", help="send a Telegram test message")
    sp.add_parser("doctor",    help="diagnose dependencies and service state")
    p_logs = sp.add_parser("logs", help="tail recent service logs")
    p_logs.add_argument("-n", type=int, default=30)

    p_setint = sp.add_parser("set-interval",
        help="set unified tick + telegram cadence in minutes (default 60)")
    p_setint.add_argument("minutes", type=int,
                          help="cadence in minutes (1-1440)")

    p_ecc_log = sp.add_parser("ecc-log",
        help="record one ECC marketplace skill usage (appends to ecc-trace.jsonl)")
    p_ecc_log.add_argument("skill",  help="ECC skill slug (e.g. autonomous-agent-harness)")
    p_ecc_log.add_argument("reason", nargs="?", default="",
                           help="short reason (why this skill was leveraged)")
    p_ecc_log.add_argument("--invoker", default="cli",
                           help="who logged it (cli/agent/tick/bot)")
    p_ecc_log.add_argument("--match-method", default="",
                           help="how the skill was matched (manual/scored/exact-slug/keyword)")
    p_ecc_log.add_argument("--match-score", type=int, default=None,
                           help="pattern-detector dedupe score (0-10)")
    p_ecc_log.add_argument("--decision-latency-ms", type=int, default=None,
                           help="ms spent deciding to leverage this skill")

    p_ecc_trace = sp.add_parser("ecc-trace",
        help="show ECC skill usage history (which ECC skills we-forge leveraged)")
    p_ecc_trace.add_argument("--last",  type=int, default=20)
    p_ecc_trace.add_argument("--group", action="store_true",
                             help="display totals per skill instead of timeline")

    p_audit = sp.add_parser("audit",
        help="audit whether high-frequency patterns were correctly classified "
             "(distinguish 'ECC covers it' from 'wrongly skipped real learning')")
    p_audit.add_argument("--top", type=int, default=30,
                         help="how many top-count patterns to show (default 30)")

    p_eccq = sp.add_parser("ecc-quality",
        help="inspect ECC_MATCH match_score distribution; flag weak matches")
    p_eccq.add_argument("--threshold", type=int, default=3,
                        help="flag entries with match_score below this (default 3)")

    p_sessions = sp.add_parser("sessions",
        help="list active Claude Code sessions (transcript activity in last N minutes)")
    p_sessions.add_argument("--window", type=int, default=60,
                            help="look-back window in minutes (default: 60)")

    p_ping = sp.add_parser("ping",
        help="register the current session with we-forge (run inside a Claude Code session)")
    p_ping.add_argument("label", nargs="?", default="",
                        help="optional label shown in sessions list")

    args = p.parse_args()
    if not args.cmd:
        p.print_help()
        return 0

    try:
        if args.cmd == "install":      return cmd_install(args.enable_telegram, args.daemon)
        if args.cmd == "uninstall":    return cmd_uninstall(deep=args.deep)
        if args.cmd == "start":        manager().start();   return 0
        if args.cmd == "stop":         manager().stop();    return 0
        if args.cmd == "restart":      manager().restart(); return 0
        if args.cmd == "status":       return cmd_status()
        if args.cmd == "set-interval": return cmd_set_interval(args.minutes)
        if args.cmd in ("run", "daemon"): return daemon_loop()
        if args.cmd == "run-once":     return run_tick_once()
        if args.cmd == "tui":          return tui()
        if args.cmd == "dashboard":    return cmd_dashboard()
        if args.cmd == "notify-test":  return cmd_notify_test()
        if args.cmd == "doctor":       return cmd_doctor()
        if args.cmd == "logs":         return cmd_logs(args.n)
        if args.cmd == "ecc-log":      return cmd_ecc_log(
            args.skill, args.reason, args.invoker,
            match_method=args.match_method,
            match_score=args.match_score,
            decision_latency_ms=args.decision_latency_ms,
        )
        if args.cmd == "ecc-trace":    return cmd_ecc_trace(args.last, args.group)
        if args.cmd == "audit":        return cmd_audit(args.top)
        if args.cmd == "ecc-quality":  return cmd_ecc_quality(args.threshold)
        if args.cmd == "sessions":     return cmd_sessions(args.window)
        if args.cmd == "ping":         return cmd_ping(args.label)
    except KeyboardInterrupt:
        print()
        return 130
    return 0

if __name__ == "__main__":
    sys.exit(main())
